# YouTube Summarizer — Credenciales
# =================================
# Valores SIN comillas. Ejemplo: KEY=valor
# Si usas python run.py setup, esto se configura automáticamente.

# GOOGLE_API_KEY (obligatorio)
# Obtén tu API key en https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy...

# GEMINI_MODEL (opcional) — modelo Gemini primario. Si Google lo retira,
# el bot cae automáticamente al siguiente de la lista interna de fallback
# (gemini-3.1-flash, gemini-2.5-flash-lite). Solo cambia esto si quieres
# pinear un modelo específico (o probar uno más nuevo).
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# TELEGRAM_BOT_TOKEN (obligatorio)
# Crea un bot con @BotFather en Telegram y pega aquí el token
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# NoteGPT.io — Credenciales para transcripción (opcional)
# Si no se configuran, se usará youtube-transcript-api como fallback
# Regístrate en https://notegpt.io
NG_EMAIL=tu@email.com
NG_PASSWORD=tu_contraseña
